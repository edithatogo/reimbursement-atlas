{
  "additionalProperties": false,
  "description": "Minimal provenance metadata for a derived record.",
  "properties": {
    "source_id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Source Id",
      "type": "string"
    },
    "source_url": {
      "anyOf": [
        {
          "format": "uri",
          "maxLength": 2083,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Url"
    },
    "retrieved_at": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Retrieved At"
    },
    "effective_date": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective Date"
    },
    "source_version": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Version"
    },
    "licence_class": {
      "default": "unknown",
      "enum": [
        "permissive",
        "public_reuse_unclear",
        "restricted",
        "unknown"
      ],
      "title": "Licence Class",
      "type": "string"
    },
    "transformation_notes": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Transformation Notes"
    }
  },
  "required": [
    "source_id"
  ],
  "title": "ProvenanceRecord",
  "type": "object"
}
