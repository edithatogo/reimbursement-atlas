{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OsfPublicationDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "reviewer",
    "reviewed_at",
    "scope",
    "approved_artifacts",
    "excluded_artifact_classes",
    "approval_reference"
  ],
  "properties": {
    "schema_version": {"const": "osf-publication-decision-v1"},
    "status": {"const": "approved_within_scope"},
    "reviewer": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "scope": {"const": "repository_data_and_research_records_only"},
    "approval_reference": {"type": "string", "minLength": 1},
    "approved_artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sha256"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "excluded_artifact_classes": {
      "type": "array",
      "contains": {"const": "papers_and_preprints"},
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
