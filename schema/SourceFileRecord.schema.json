{
  "additionalProperties": false,
  "description": "Exact file, endpoint or landing page needed for a source-version acquisition.",
  "properties": {
    "id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Id",
      "type": "string"
    },
    "source_id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Source Id",
      "type": "string"
    },
    "source_version_id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Source Version Id",
      "type": "string"
    },
    "file_label": {
      "minLength": 1,
      "title": "File Label",
      "type": "string"
    },
    "file_name": {
      "minLength": 1,
      "title": "File Name",
      "type": "string"
    },
    "source_url": {
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "title": "Source Url",
      "type": "string"
    },
    "file_role": {
      "enum": [
        "primary",
        "supplementary",
        "landing_page",
        "licence_gate",
        "api_endpoint"
      ],
      "title": "File Role",
      "type": "string"
    },
    "expected_format": {
      "minLength": 1,
      "title": "Expected Format",
      "type": "string"
    },
    "acquisition_mode": {
      "enum": [
        "manual_download",
        "manual_extract",
        "api_rate_limited",
        "landing_page_review",
        "licence_clickthrough_manual"
      ],
      "title": "Acquisition Mode",
      "type": "string"
    },
    "licence_gate": {
      "enum": [
        "permissive_candidate",
        "public_reuse_review",
        "restricted_or_licence_review",
        "metadata_only"
      ],
      "title": "Licence Gate",
      "type": "string"
    },
    "parser_hint": {
      "minLength": 1,
      "title": "Parser Hint",
      "type": "string"
    },
    "expected_record_count": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expected Record Count"
    },
    "current_observation": {
      "minLength": 1,
      "title": "Current Observation",
      "type": "string"
    },
    "notes": {
      "minLength": 1,
      "title": "Notes",
      "type": "string"
    }
  },
  "required": [
    "id",
    "source_id",
    "source_version_id",
    "file_label",
    "file_name",
    "source_url",
    "file_role",
    "expected_format",
    "acquisition_mode",
    "licence_gate",
    "parser_hint",
    "current_observation",
    "notes"
  ],
  "title": "SourceFileRecord",
  "type": "object"
}
