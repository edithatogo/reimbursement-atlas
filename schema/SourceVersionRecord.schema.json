{
  "additionalProperties": false,
  "description": "A specific retrievable source version or fixture target.",
  "properties": {
    "id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Id",
      "type": "string"
    },
    "source_id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Source Id",
      "type": "string"
    },
    "version_label": {
      "minLength": 1,
      "title": "Version Label",
      "type": "string"
    },
    "source_url": {
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "title": "Source Url",
      "type": "string"
    },
    "format": {
      "minLength": 1,
      "title": "Format",
      "type": "string"
    },
    "parser_status": {
      "enum": [
        "planned",
        "stubbed",
        "prototype",
        "validated",
        "production"
      ],
      "title": "Parser Status",
      "type": "string"
    },
    "effective_from": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective From"
    },
    "effective_to": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective To"
    },
    "retrieved_at": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Retrieved At"
    },
    "checksum_sha256": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Checksum Sha256"
    },
    "notes": {
      "minLength": 1,
      "title": "Notes",
      "type": "string"
    }
  },
  "required": [
    "id",
    "source_id",
    "version_label",
    "source_url",
    "format",
    "parser_status",
    "notes"
  ],
  "title": "SourceVersionRecord",
  "type": "object"
}
