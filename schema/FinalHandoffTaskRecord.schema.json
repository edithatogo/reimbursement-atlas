      "type": "string"
    },
    "required_environment": {
      "minLength": 1,
      "title": "Required Environment",
      "type": "string"
    },
    "command": {
      "minLength": 1,
      "title": "Command",
      "type": "string"
    },
    "evidence_path": {
      "minLength": 1,
      "title": "Evidence Path",
      "type": "string"
    },
    "unblock_condition": {
      "minLength": 1,
      "title": "Unblock Condition",
      "type": "string"
    },
    "recommended_action": {
      "minLength": 1,
      "title": "Recommended Action",
      "type": "string"
    }
  },
  "required": [
    "id",
    "task_group",
    "title",
    "status",
    "required_environment",
    "command",
    "evidence_path",
    "unblock_condition",
