{
  "additionalProperties": false,
  "description": "Generated task that remains for a network-enabled or credentialed environment.",
  "properties": {
    "id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Id",
      "type": "string"
    },
    "conductor_track": {
      "minLength": 1,
      "title": "Conductor Track",
      "type": "string"
    },
    "github_issues": {
      "default": [],
      "items": {
        "type": "integer"
      },
      "title": "Github Issues",
      "type": "array"
    },
    "task_group": {
      "enum": [
        "source_ingestion",
        "security",
        "publication",
        "release",
        "research",
        "automation",
        "mappings"
      ],
      "title": "Task Group",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "status": {
      "enum": [
        "ready_local",
        "partial",
        "blocked_network",
        "blocked_secret",
        "blocked_review",
        "complete"
      ],
      "title": "Status",
      "type": "string"
    },
    "required_environment": {
      "minLength": 1,
      "title": "Required Environment",
      "type": "string"
    },
    "command": {
      "minLength": 1,
      "title": "Command",
      "type": "string"
    },
    "evidence_path": {
      "minLength": 1,
      "title": "Evidence Path",
      "type": "string"
    },
    "unblock_condition": {
      "minLength": 1,
      "title": "Unblock Condition",
      "type": "string"
    },
    "recommended_action": {
      "minLength": 1,
      "title": "Recommended Action",
      "type": "string"
    },
    "reason_code": {
      "default": "unspecified",
      "minLength": 1,
      "title": "Reason Code",
      "type": "string"
    },
    "gate_evidence": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Gate Evidence",
      "type": "array"
    },
    "review_record": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Review Record"
    },
    "external_state": {
      "default": "pending",
      "enum": [
        "not_applicable",
        "pending",
        "ready",
        "submitted",
        "published"
      ],
      "title": "External State",
      "type": "string"
    },
    "last_verified_at": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Verified At"
    }
  },
  "required": [
    "id",
    "conductor_track",
    "task_group",
    "title",
    "status",
    "required_environment",
    "command",
    "evidence_path",
    "unblock_condition",
    "recommended_action"
  ],
  "title": "FinalHandoffTaskRecord",
  "type": "object"
}
