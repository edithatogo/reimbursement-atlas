  "properties": {
    "id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Id",
      "type": "string"
    },
    "task_group": {
      "enum": [
        "source_ingestion",
        "security",
        "publication",
        "release",
        "research",
        "automation"
