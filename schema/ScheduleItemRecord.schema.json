{
  "$defs": {
    "ProvenanceRecord": {
      "additionalProperties": false,
      "description": "Minimal provenance metadata for a derived record.",
      "properties": {
        "source_id": {
          "pattern": "^[a-z0-9_]+$",
          "title": "Source Id",
          "type": "string"
        },
        "source_url": {
          "anyOf": [
            {
              "format": "uri",
              "maxLength": 2083,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Url"
        },
        "retrieved_at": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retrieved At"
        },
        "effective_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective Date"
        },
        "source_version": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        },
        "licence_class": {
          "default": "unknown",
          "enum": [
            "permissive",
            "public_reuse_unclear",
            "restricted",
            "unknown"
          ],
          "title": "Licence Class",
          "type": "string"
        },
        "transformation_notes": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transformation Notes"
        }
      },
      "required": [
        "source_id"
      ],
      "title": "ProvenanceRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Normalised schedule item after source-specific parsing.",
  "properties": {
    "source_id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Source Id",
      "type": "string"
    },
    "jurisdiction": {
      "minLength": 1,
      "title": "Jurisdiction",
      "type": "string"
    },
    "domain": {
      "minLength": 1,
      "title": "Domain",
      "type": "string"
    },
    "code_system": {
      "minLength": 1,
      "title": "Code System",
      "type": "string"
    },
    "item_code": {
      "minLength": 1,
      "title": "Item Code",
      "type": "string"
    },
    "item_label": {
      "minLength": 1,
      "title": "Item Label",
      "type": "string"
    },
    "item_description": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Item Description"
    },
    "payment_amount": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Payment Amount"
    },
    "currency": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Currency"
    },
    "payment_unit": {
      "default": "item",
      "minLength": 1,
      "title": "Payment Unit",
      "type": "string"
    },
    "patient_amount": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Patient Amount"
    },
    "effective_from": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective From"
    },
    "effective_to": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective To"
    },
    "restriction_text": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Restriction Text"
    },
    "setting": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Setting"
    },
    "professional_component": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Professional Component"
    },
    "facility_component": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Facility Component"
    },
    "provenance": {
      "$ref": "#/$defs/ProvenanceRecord"
    }
  },
  "required": [
    "source_id",
    "jurisdiction",
    "domain",
    "code_system",
    "item_code",
    "item_label",
    "provenance"
  ],
  "title": "ScheduleItemRecord",
  "type": "object"
}
