{
  "additionalProperties": false,
  "description": "Metadata for a local source snapshot or derived-only acquisition event.",
  "properties": {
    "id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Id",
      "type": "string"
    },
    "source_id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Source Id",
      "type": "string"
    },
    "source_version_id": {
      "pattern": "^[a-z0-9_]+$",
      "title": "Source Version Id",
      "type": "string"
    },
    "source_url": {
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "title": "Source Url",
      "type": "string"
    },
    "local_path": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Local Path"
    },
    "retrieved_at": {
      "minLength": 1,
      "title": "Retrieved At",
      "type": "string"
    },
    "content_type": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content Type"
    },
    "byte_size": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Byte Size"
    },
    "checksum_sha256": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Checksum Sha256"
    },
    "licence_gate": {
      "enum": [
        "permissive",
        "public_reuse_review",
        "restricted_local_only"
      ],
      "title": "Licence Gate",
      "type": "string"
    },
    "cache_scope": {
      "enum": [
        "public_raw_cache",
        "public_derived_only",
        "local_raw_only",
        "metadata_only"
      ],
      "title": "Cache Scope",
      "type": "string"
    },
    "notes": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Notes"
    }
  },
  "required": [
    "id",
    "source_id",
    "source_version_id",
    "source_url",
    "retrieved_at",
    "licence_gate",
    "cache_scope"
  ],
  "title": "SourceSnapshotRecord",
  "type": "object"
}
