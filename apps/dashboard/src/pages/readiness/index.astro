---
import DataTable from "../../components/DataTable.astro";
import Layout from "../../components/Layout.astro";
---

<Layout title="Reimbursement Atlas readiness">
  <h1>Readiness artefacts</h1>
  <p>
    These CSVs are dashboard-safe generated metadata. They should not include proprietary
    descriptors, restricted ontology dumps, or confidential net prices.
  </p>
  <DataTable
    title="Licence review queue"
    description="Checksum-bound publication candidates remain pending until an accountable human reviewer records decision evidence. Queue generation never grants approval."
    fileName="licence_review_queue.csv"
    columns={["review_id", "relative_path", "checksum_sha256", "publication_scope", "licence_gate", "review_status"]}
    limit={12}
  />
  <DataTable
    title="Source readiness"
    fileName="source_readiness.csv"
    columns={["source_id", "jurisdiction", "schedule", "domain", "grade", "score"]}
  />
  <DataTable
    title="Analysis readiness"
    fileName="analysis_readiness.csv"
    columns={["analysis_id", "policy_domain", "readiness_grade", "score", "priority"]}
  />
  <DataTable
    title="Ingestion readiness"
    fileName="ingestion_readiness.csv"
    columns={["source_id", "version_id", "parser_name", "readiness_grade", "blocking_issues"]}
  />
  <DataTable
    title="Historical MBS archive inventory"
    fileName="historical_mbs_archive_targets.csv"
    columns={["archive_period", "file_name", "file_kind", "archive_page_id", "download_policy", "status"]}
  />
  <DataTable
    title="External quality gates"
    fileName="external_quality_gates.csv"
    columns={["id", "outcome", "command", "notes"]}
  />
  <DataTable
    title="Optional toolchain install probes"
    fileName="optional_toolchain_installs.csv"
    columns={["id", "outcome", "command", "notes"]}
  />

  <DataTable
    title="Data quality checks"
    fileName="data_quality_checks.csv"
    columns={["id", "table_name", "check_name", "severity", "status", "observed_value", "expected_value", "recommended_action"]}
  />
  <DataTable
    title="Source/schema drift checks"
    fileName="source_drift_report.csv"
    columns={["id", "left_label", "right_label", "status", "left_row_count", "right_row_count", "row_count_delta", "added_columns", "removed_columns", "recommended_action"]}
  />
  <DataTable
    title="Data dictionary"
    fileName="data_dictionary.csv"
    columns={["table_name", "relative_path", "file_format", "row_count", "column_count", "publication_scope", "licence_gate"]}
  />
</Layout>
