---
import DataTable from "../../components/DataTable.astro";
import Layout from "../../components/Layout.astro";
---

<Layout title="Reimbursement Atlas sources">
  <h1>Sources</h1>
  <p>
    Source pages emphasise acquisition status, reproducibility and licence gates before any raw
    public schedule is mirrored or transformed into derived outputs.
  </p>
  <DataTable
    title="Current source observations"
    fileName="source_status.csv"
    columns={["source_id", "status_label", "retrieval_priority", "recommended_action", "evidence_url"]}
  />
  <DataTable
    title="Source acquisition plan"
    fileName="source_acquisition_plan.csv"
    columns={["source_id", "version_id", "acquisition_mode", "expected_format", "licence_gate", "cache_policy"]}
  />
  <DataTable
    title="Exact source files and licence gates"
    fileName="source_files.csv"
    columns={["id", "source_id", "file_name", "acquisition_mode", "licence_gate", "current_observation"]}
  />
  <DataTable
    title="Manual acquisition pack"
    fileName="acquisition_steps.csv"
    columns={["step_id", "source_file_id", "source_id", "acquisition_mode", "raw_handling", "suggested_local_path"]}
  />
  <DataTable
    title="Executable download plans"
    fileName="download_plans.csv"
    columns={["source_file_id", "method", "should_execute", "supports_resume", "captures_headers", "licence_gate", "notes"]}
  />
  <DataTable
    title="Source snapshots"
    fileName="source_snapshots.csv"
    columns={["source_version_id", "snapshot_id", "content_type", "byte_count", "sha256", "licence_gate"]}
  />
  <DataTable
    title="Source-content validation"
    fileName="source_content_validation.csv"
    columns={["source_file_id", "validation_status", "expected_format", "observed_record_count", "byte_size", "issues", "recommended_action"]}
  />
</Layout>
