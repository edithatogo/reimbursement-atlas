---
import DataTable from "../../components/DataTable.astro";
import Layout from "../../components/Layout.astro";
---

<Layout title="Reimbursement Atlas automation">
  <h1>Repository automation and supply-chain posture</h1>
  <p>
    These tables expose CI/CD, workflow policy, SBOM and automation controls as dashboard-safe
    metadata. They are designed for maintainer review before GitHub branch protection and release
    publication gates are made mandatory.
  </p>
  <DataTable
    title="Automation controls"
    fileName="automation_controls.csv"
    columns={["id", "category", "status", "maturity", "evidence", "recommended_next_step"]}
  />
  <DataTable
    title="Workflow policy observations"
    fileName="workflow_policy.csv"
    columns={["workflow", "gate", "status", "severity", "evidence", "recommended_action"]}
  />
  <DataTable
    title="GitHub Action references"
    fileName="workflow_uses.csv"
    columns={["workflow", "line", "uses", "pin_class", "policy_status", "policy_note"]}
  />
  <DataTable
    title="Action SHA pin plan"
    fileName="action_sha_pin_plan.csv"
    columns={["workflow", "line", "uses", "pin_class", "priority", "recommended_action"]}
  />

  <DataTable
    title="Action pin resolution"
    fileName="action_pin_resolution.csv"
    columns={["workflow", "line", "current_uses", "status", "suggested_uses", "notes"]}
  />
  <DataTable
    title="SBOM summaries"
    fileName="sbom_summary.csv"
    columns={["name", "ecosystem", "component_count", "spec_version", "sha256"]}
  />

  <DataTable
    title="Local quality-gate run"
    fileName="local_quality_gates.csv"
    columns={["id", "category", "status", "blocking", "duration_seconds", "notes"]}
  />
  <DataTable
    title="Local quality-gate specifications"
    fileName="local_quality_gate_specs.csv"
    columns={["id", "category", "command", "profiles", "blocking", "timeout_seconds"]}
  />

  <DataTable
    title="Architecture layer policy"
    fileName="layer_policy.csv"
    columns={["id", "source_layer", "target_layer", "status", "edge_count", "recommended_action"]}
  />
  <DataTable
    title="Internal import edges"
    fileName="import_edges.csv"
    columns={["source_module", "target_module", "source_layer", "target_layer", "allowed", "reason"]}
  />
  <DataTable
    title="GitHub Project import items"
    fileName="github_project_items.csv"
    columns={["item_type", "title", "epic_id", "status", "priority", "milestone", "project_view"]}
  />
  <DataTable
    title="Release-readiness gates"
    fileName="release_gates.csv"
    columns={["id", "category", "status", "required", "evidence", "recommended_action"]}
  />
  <DataTable
    title="Final handoff tasks"
    fileName="final_handoff_tasks.csv"
    columns={["task_group", "title", "status", "required_environment", "command", "recommended_action"]}
  />
</Layout>
