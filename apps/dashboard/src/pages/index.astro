---
import Graph from "../components/Graph.tsx";
import Layout from "../components/Layout.astro";
import StatusOverview from "../components/StatusOverview.astro";
---

<Layout
  title="Reimbursement Atlas"
  description="Citable, provenance-aware dashboard for public reimbursement metadata and research readiness."
>
  <h1>Reimbursement Atlas</h1>
  <p>
    A public, citable software surface for exploring reimbursement sources, policy analyses,
    source versions and ontology mapping strategy. Every view is built from generated artefacts,
    not raw restricted schedule dumps.
  </p>
  <StatusOverview />
  <section id="graph">
    <h2>Evidence graph</h2>
    <p class="muted">Explore relationships between sources, questions, mappings and outputs.</p>
  </section>
  <Graph client:only="react" baseUrl={import.meta.env.BASE_URL} />
</Layout>
