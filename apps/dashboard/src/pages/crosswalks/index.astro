---
import DataTable from "../../components/DataTable.astro";
import Layout from "../../components/Layout.astro";
import ProvenancePanel from "../../components/ProvenancePanel.astro";
---

<Layout title="Reimbursement Atlas crosswalks">
  <h1>Crosswalks</h1>
  <p>
    Crosswalks are candidate mappings only. They require domain review before they are used in
    policy estimates, price comparisons or uptake analysis.
  </p>
  <ProvenancePanel
    title="Mapping evidence is reviewable"
    description="Candidate mappings expose their evidence fields, while gold standards and negative controls remain separate review surfaces."
    links={[
      { label: "Mapping evidence matrix", href: "#mapping-evidence" },
      { label: "Gold standards", href: "#gold-standard" },
      { label: "Negative controls", href: "#negative-controls" },
    ]}
  />
  <DataTable
    title="Mapping review status"
    description="This status row is a fail-closed review aid. It never converts candidate mappings into approved or evidence-ready mappings."
    fileName="mapping_review_status.csv"
    columns={[
      "status",
      "candidate_count",
      "mapping_evidence_count",
      "gold_standard_count",
      "negative_control_count",
      "triggered_negative_control_count",
      "reviewer_signoff_required",
      "evidence_ready",
      "recommended_review_threshold",
      "next_action",
    ]}
    limit={1}
  />
  <DataTable
    title="Crosswalk review queue"
    fileName="crosswalk_review_queue.csv"
    columns={[
      "left_source_id",
      "left_code",
      "right_source_id",
      "right_code",
      "confidence",
      "priority",
      "recommended_action",
    ]}
  />
  <DataTable
    title="Candidate crosswalks"
    fileName="crosswalk_candidates.csv"
    columns={[
      "left_source_id",
      "left_code",
      "right_source_id",
      "right_code",
      "relationship",
      "confidence",
      "evidence_methods",
    ]}
  />
  <DataTable
    title="Mapping evidence matrix"
    id="mapping-evidence"
    fileName="mapping_evidence_matrix.csv"
    columns={[
      "left_source_id",
      "left_code",
      "right_source_id",
      "right_code",
      "token_jaccard",
      "hash_cosine",
      "price_ratio",
      "confidence",
      "review_priority",
    ]}
  />
  <DataTable
    title="Gold-standard mappings"
    id="gold-standard"
    fileName="gold_standard_mappings.csv"
    columns={[
      "left_source_id",
      "left_code",
      "right_source_id",
      "right_code",
      "relationship",
      "reviewer",
      "reviewed_at",
      "notes",
    ]}
  />
  <DataTable
    title="Negative controls"
    id="negative-controls"
    fileName="negative_controls.csv"
    columns={[
      "left_source_id",
      "left_code",
      "right_source_id",
      "right_code",
      "reason_not_equivalent",
      "reviewer",
      "reviewed_at",
    ]}
  />
  <DataTable
    title="Calibration cases"
    fileName="mapping_calibration_cases.csv"
    columns={[
      "case_type",
      "left_source_id",
      "left_code",
      "right_source_id",
      "right_code",
      "expected_outcome",
      "observed_outcome",
      "candidate_confidence",
    ]}
  />
  <DataTable
    title="Calibration summary"
    fileName="mapping_calibration_summary.csv"
    columns={[
      "gold_standard_count",
      "matched_gold_standard_count",
      "missed_gold_standard_count",
      "negative_control_count",
      "triggered_negative_control_count",
      "estimated_recall",
      "estimated_precision",
      "estimated_specificity",
      "recommended_review_threshold",
    ]}
  />
</Layout>
