---
interface Props {
  title: string;
  description: string;
  links: { label: string; href: string }[];
}

const { title, description, links } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const publicPath = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
---

<aside class="provenance-panel" aria-labelledby="provenance-heading">
  <p class="eyebrow">Provenance</p>
  <h2 id="provenance-heading">{title}</h2>
  <p class="muted">{description}</p>
  <ul>
    {links.map((link) => <li><a href={publicPath(link.href)}>{link.label}</a></li>)}
  </ul>
</aside>
